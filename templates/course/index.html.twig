{% extends 'layout.html.twig' %}

{% block title %}Upload a course{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <h1 class="h3 mb-4">Upload course material</h1>
                    {{ form_start(form) }}
                    {{ form_row(form.title, {label: 'Title'}) }}
                    {{ form_row(form.summary, {label: 'Summary'}) }}
                    {{ form_row(form.file, {label: 'Course file'}) }}
                    <button class="btn btn-primary" type="submit">Save</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
