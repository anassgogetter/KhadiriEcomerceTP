{% extends 'layout.html.twig' %}

{% block title %}{{ course.title }}{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-body">
            <h1>{{ course.title }}</h1>
            <p class="text-muted">Added on {{ course.createdAt|date('m/d/Y H:i') }}</p>
            <p>{{ course.summary ?: 'No summary yet.' }}</p>
            {% if course.filePath %}
                <a href="{{ asset(course.filePath) }}" class="btn btn-primary">Download material</a>
            {% endif %}
            <a href="{{ path('app_course_all') }}" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
{% endblock %}
