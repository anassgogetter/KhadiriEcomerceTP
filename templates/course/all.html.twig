{% extends 'layout.html.twig' %}

{% block title %}Library{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Library</h1>
        <a href="{{ path('app_course') }}" class="btn btn-primary">Add a course</a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for course in list %}
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>{{ course.title }}</h5>
                        <p>{{ course.summary ?: 'No summary yet.' }}</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <a href="{{ path('app_course_show', {identifier: course.id}) }}" class="btn btn-outline-primary btn-sm">View</a>
                        {% if course.filePath %}
                            <a href="{{ asset(course.filePath) }}" class="btn btn-outline-secondary btn-sm">Download</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col">
                <div class="alert alert-info">No uploaded courses yet.</div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
