{% extends 'layout.html.twig' %}

{% block title %}Create account{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h1 class="h3 mb-4">Create your account</h1>
                    {{ form_start(registerForm) }}
                    {{ form_row(registerForm.fullName, {label: 'Full name'}) }}
                    {{ form_row(registerForm.email, {label: 'Email'}) }}
                    {{ form_row(registerForm.phone, {label: 'Phone'}) }}
                    {{ form_row(registerForm.password) }}
                    <button class="btn btn-primary" type="submit">Register</button>
                    {{ form_end(registerForm) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
