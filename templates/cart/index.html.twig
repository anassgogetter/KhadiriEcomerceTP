{% extends 'layout.html.twig' %}

{% block title %}Cart{% endblock %}

{% block content %}
    <h1>Cart</h1>
    {% if cart is empty %}
        <div class="alert alert-info">Your cart is empty.</div>
        <a href="{{ path('app_catalog_all') }}" class="btn btn-primary">Back to catalog</a>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Format</th>
                        <th>Quantity</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart %}
                        <tr>
                            <td>{{ item.name }}</td>
                            <td>{{ item.format }}</td>
                            <td>{{ item.quantity }}</td>
                            <td>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} DH</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <h3>Total : {{ total|number_format(2, ',', ' ') }} DH</h3>
            <div>
                <a href="{{ path('app_cart_clear') }}" class="btn btn-outline-secondary">Clear</a>
                <a href="{{ path('app_checkout') }}" class="btn btn-primary">Checkout</a>
            </div>
        </div>
    {% endif %}
{% endblock %}
